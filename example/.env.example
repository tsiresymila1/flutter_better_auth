GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
BETTER_AUTH_URL=https://your-server.example.com/api/auth
# Google native idToken sign-in. Server client id = the OAuth WEB client id used
# by the Better Auth server's socialProviders.google.clientId.
GOOGLE_SERVER_CLIENT_ID=your_google_web_oauth_client_id
GOOGLE_IOS_CLIENT_ID=your_google_ios_oauth_client_id
